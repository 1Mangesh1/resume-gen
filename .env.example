# ── n8n Configuration ──────────────────────────────────────────
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
TIMEZONE=UTC

# ── Google Gemini (required) ─────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# ── Cloudflare Browser Rendering (optional) ──────────────────────
# Used as primary scraper for job description URLs.
# If not set, falls back to Jina AI (free, no auth).
# API Token needs "Browser Rendering - Edit" permission.
# Get token: https://dash.cloudflare.com/profile/api-tokens
# Account ID: https://dash.cloudflare.com → right sidebar
CF_API_TOKEN=
CF_ACCOUNT_ID=
