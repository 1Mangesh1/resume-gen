        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({\n  pdf_base64:       $json.pdf_base64       ?? null,\n  tex_source:       $json.tex_source       ?? '',\n  ats_score:        $json.ats_score        ?? null,\n  matched_keywords: $json.matched_keywords ?? [],\n  compile_error:    $json.compile_error    ?? null,\n  generated_at:     $json.generated_at     ?? new Date().toISOString(),\n  status:           $json.status           ?? 'error'\n}) }}",
        "options": {
          "responseHeaders": {
            "entries": [
