    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:5678/webhook/output-handler",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  pdf_base64:       $json.pdf_base64       ?? null,\n  tex_source:       $json.tex_source       ?? '',\n  ats_score:        $('Call AI Tailoring Engine').item.json.ats_score        ?? null,\n  matched_keywords: $('Call AI Tailoring Engine').item.json.matched_keywords ?? [],\n  compile_error:    $json.compile_error    ?? null\n}) }}",
        "options": {
          "timeout": 10000
        }
      },
      "id": "c3d4e5f6-0003-4000-8000-000000000011",
      "name": "Call Output Handler",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
