    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ pdf_base64: $json.pdf_base64 ?? null, tex_source: $json.tex_source ?? '', ats_score: $json.ats_score ?? null, matched_keywords: $json.matched_keywords ?? [], status: $json.status ?? 'error' }) }}",
        "options": {
          "responseHeaders": {
            "entries": [
